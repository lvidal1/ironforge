# OpenClaw Gateway Authentication Token
# Generate one with: openssl rand -hex 32
# Or use any random string (at least 20 characters recommended)
OPENCLAW_GATEWAY_TOKEN=<replace-with-your-gateway-token>

# Discord Bot Token
# Get from Discord Developer Portal > Your Application > Bot > Reset Token
DISCORD_BOT_TOKEN=<replace-with-discord-bot-token>

# Slack App-Level Token (Socket Mode)
# Get from Slack App Dashboard: Basic Information → App-Level Tokens → Generate Token
# Required scope: connections:write
SLACK_APP_TOKEN=<replace-with-slack-app-token>

# Slack Bot Token
# Get from Slack App Dashboard: Install App → Install to Workspace
SLACK_BOT_TOKEN=<replace-with-slack-bot-token>
