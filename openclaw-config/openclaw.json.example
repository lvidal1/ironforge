{
  "models": {
    "providers": {
      "llama": {
        "baseUrl": "http://llama_backend:8081/v1",
        "api": "openai-completions",
        "apiKey": "sk-no-key-required"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "llama/Qwen3.6-35B-A3B"
      }
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.5.19",
    "lastTouchedAt": "<replace-with-current-timestamp>"
  },
  "gateway": {
    "auth": {
      "token": "<replace-with-gateway-token-from-.env>"
    },
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789"
      ]
    }
  },
  "plugins": {
    "entries": {
      "duckduckgo": {
        "enabled": true,
        "config": {
          "webSearch": {
            "region": "es-es",
            "safeSearch": "moderate"
          }
        }
      },
      "discord": {
        "enabled": true
      },
      "slack": {
        "enabled": true
      }
    }
  },
  "channels": {
    "discord": {
      "accounts": {
        "default": {
          "token": {
            "source": "env",
            "provider": "default",
            "id": "DISCORD_BOT_TOKEN"
          }
        }
      }
    },
    "slack": {
      "enabled": true,
      "mode": "socket",
      "appToken": {
        "source": "env",
        "provider": "default",
        "id": "SLACK_APP_TOKEN"
      },
      "botToken": {
        "source": "env",
        "provider": "default",
        "id": "SLACK_BOT_TOKEN"
      }
    }
  },
  "tools": {
    "web": {
      "search": {
        "provider": "duckduckgo"
      }
    }
  },
  "messages": {
    "groupChat": {
      "mentionPatterns": [
        "@Ironforge",
        "@ironforge",
        "@Iron Forge",
        "@iron forge"
      ]
    }
  }
}

